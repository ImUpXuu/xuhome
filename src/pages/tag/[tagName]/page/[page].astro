---
import { getProcessedPosts } from '../../../../utils/postsFetcher';

export async function getStaticPaths() {
  const allPosts = await getProcessedPosts();
  const tagsSet = new Set<string>();
  allPosts.forEach(p => {
    if (p.tags) {
      p.tags.forEach(t => tagsSet.add(t));
    }
  });
  
  const paths = [];
  for (const tag of tagsSet) {
    for (let p = 1; p <= 15; p++) {
      paths.push({
        params: { tagName: tag, page: String(p) }
      });
    }
  }
  return paths;
}

const { tagName, page } = Astro.params;
return Astro.redirect(`/tag/${encodeURIComponent(tagName || '')}?page=${page}`);
---
