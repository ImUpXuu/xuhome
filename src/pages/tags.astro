---
import Layout from '../layouts/Layout.astro';
import { getProcessedPosts } from '../utils/postsFetcher';
import { i18nConfig } from '../config/site';

const allPosts = await getProcessedPosts();

const tagMap: Record<string, number> = {};
allPosts.forEach(post => {
  if (post.tags) {
    post.tags.forEach(tag => {
      tagMap[tag] = (tagMap[tag] || 0) + 1;
    });
  }
});

const tags = Object.entries(tagMap)
  .map(([name, count]) => ({ name, count }))
  .sort((a, b) => b.count - a.count);
---

<Layout
  title="标签 - 全部"
  description="UpXuu 博客全部标签"
  postsCount={tags.length}
>
  <div class="w-full max-w-3xl mx-auto">
    <div class="bg-white dark:bg-slate-800 border-4 border-[#0284c7] p-6 md:p-10 shadow-[6px_6px_0px_0px_#0284c7] rounded-sm animate-card-entrance opacity-0">
      <div class="flex items-center gap-3 mb-6 border-b-2 border-dashed border-[#0284c7]/20 pb-4">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 stroke-[2.5] text-[#0284c7]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M7 20l4-16m2 16l4-16M6 9h14M4 15h14" />
        </svg>
        <h1 class="text-xl md:text-2xl font-black text-[#0284c7]">
          标签
        </h1>
        <span class="text-xs font-bold text-slate-400 font-mono">({tags.length} 个)</span>
      </div>

      <div class="flex flex-wrap gap-3">
        {tags.map(tag => (
          <a
            href={`/tag/${tag.name}`}
            class="group inline-flex items-center gap-2 px-4 py-2 bg-[rgba(250,248,245,0.18)] dark:bg-slate-700 border-2 border-[#0284c7] rounded-sm shadow-[3px_3px_0px_0px_#0284c7] hover:shadow-none hover:translate-x-0.5 hover:translate-y-0.5 transition-all duration-200"
          >
            <span class="font-black text-sm text-slate-700 dark:text-slate-200 group-hover:text-[#0ea5e9] transition-colors">#{tag.name}</span>
            <span class="text-[10px] font-bold text-slate-400 font-mono bg-white dark:bg-slate-600 border border-[#0284c7]/20 px-1.5 py-0.5 rounded-sm">{tag.count}</span>
          </a>
        ))}
      </div>
    </div>
  </div>
</Layout>
