---import Layout from '../layouts/Layout.astro';import { siteConfig, aboutConfig } from '../config/site';import { Content } from '../config/about.md';import ServerStatus from '../components/ServerStatus.svelte';const skills = aboutConfig.skills;const GITHUB_USER = siteConfig.socials.githubUser;const BILIBILI_MID = siteConfig.socials.bilibiliMid;const BILIBILI_SPACE = siteConfig.socials.bilibili;interface GitHubRepo {  name: string;  description: string | null;  html_url: string;  language: string | null;  stargazers_count: number;  forks_count: number;  topics: string[];}interface BiliVideo {  bvid: string;  title: string;  cover: string;  duration: number;  play_count: number;  publish_time: number;}let repos: GitHubRepo[] = [];try {  const res = await fetch(`https://api.github.com/users/${GITHUB_USER}/repos?sort=updated&per_page=100`);  if (res.ok) {    const data = await res.json();    repos = data.map((r: any) => ({      name: r.name,      description: r.description,      html_url: r.html_url,      language: r.language,      stargazers_count: r.stargazers_count,      forks_count: r.forks_count,      topics: r.topics || [],    }));  }} catch (e) {  console.error('Failed to fetch GitHub repos', e);}let biliVideos: BiliVideo[] = [];try {  const firstRes = await fetch(`https://uapis.cn/api/v1/social/bilibili/archives?mid=${BILIBILI_MID}&ps=30`);  if (firstRes.ok) {    const firstData = await firstRes.json();    const total = firstData.total || 0;    const firstBatch: BiliVideo[] = (firstData.videos || []).map((v: any) => ({      bvid: v.bvid, title: v.title, cover: v.cover,      duration: v.duration, play_count: v.play_count, publish_time: v.publish_time,    }));    biliVideos = firstBatch;    const totalPages = Math.ceil(total / 30);    for (let p = 2; p <= totalPages; p++) {      const res = await fetch(`https://uapis.cn/api/v1/social/bilibili/archives?mid=${BILIBILI_MID}&ps=30&pn=${p}`);      if (res.ok) {        const data = await res.json();        const more: BiliVideo[] = (data.videos || []).map((v: any) => ({          bvid: v.bvid, title: v.title, cover: v.cover,          duration: v.duration, play_count: v.play_count, publish_time: v.publish_time,        }));        biliVideos = biliVideos.concat(more);      }    }  }} catch (e) {  console.error('Failed to fetch Bilibili videos', e);}function fmtDuration(sec: number): string {  const m = Math.floor(sec / 60);  const s = sec % 60;  return `${m}:${s.toString().padStart(2, '0')}`;}function fmtPlayCount(n: number): string {  if (n >= 10000) return (n / 10000).toFixed(1) + 'õĖ?;  if (n >= 1000) return (n / 1000).toFixed(1) + 'k';  return String(n);}---<Layout   title={aboutConfig.title}  description={aboutConfig.description}  isAboutPage={true}>  <div class="max-w-[1440px] w-full mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-12">    <div class="max-w-5xl mx-auto space-y-8 animate-card-entrance">            {/* Profile Header */}      <div class="bg-white border-4 border-[#0284c7] p-8 shadow-[8px_8px_0px_0px_#f59e0b] rounded-sm relative">        <div class="flex flex-col md:flex-row items-center gap-8">          <div class="w-32 h-32 md:w-40 md:h-40 rounded-sm bg-[#0ea5e9] border-4 border-[#0284c7] shadow-[4px_4px_0px_0px_#0284c7] overflow-hidden flex items-center justify-center shrink-0">            <img src={siteConfig.avatar} alt={siteConfig.author} width="160" height="160" loading="lazy" class="w-full h-full object-cover" />          </div>          <div class="text-center md:text-left">            <h1 class="text-2xl md:text-4xl font-black text-[#0284c7] tracking-wider mb-2">{siteConfig.author}</h1>            <p class="text-lg md:text-xl font-bold text-slate-600 mb-4 font-mono select-none">              <span class="bg-[#fde68a] px-2 py-0.5 border-2 border-[#0284c7] shadow-[2px_2px_0px_0px_#0284c7] inline-block">{aboutConfig.role}</span>            </p>            <p class="text-slate-700 leading-relaxed font-medium">              {aboutConfig.intro}            </p>        