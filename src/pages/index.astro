---
import Layout from '../layouts/Layout.astro';
import { getProcessedPosts } from '../utils/postsFetcher';
import HorizontalCategories from '../components/HorizontalCategories.astro';
import LeftSidebar from '../components/LeftSidebar.astro';
import PostsTimelineWidget from '../components/PostsTimelineWidget.astro';
import SearchablePosts from '../components/SearchablePosts.svelte';

const allPosts = await getProcessedPosts();

// Process category counts
const catMap: Record<string, number> = {};
const tagMap: Record<string, number> = {};

allPosts.forEach(post => {
  if (post.category) {
    catMap[post.category] = (catMap[post.category] || 0) + 1;
  }
  if (post.tags) {
    post.tags.forEach(tag => {
      tagMap[tag] = (tagMap[tag] || 0) + 1;
    });
  }
});

const categories = Object.entries(catMap)
  .map(([name, count]) => ({ name, count }))
  .sort((a, b) => b.count - a.count);
  
const tags = Object.entries(tagMap)
  .map(([name, count]) => ({ name, count }))
  .sort((a, b) => b.count - a.count);
---

<Layout 
  title="首页"
  description="UpXuu的个人博客 - 记录生活、学习、编程与思考的原创文章。"
  postsCount={allPosts.length}
>
  <HorizontalCategories 
    categories={categories} 
    activeCategory={null} 
  />

  <div class="flex flex-col xl:flex-row gap-4 sm:gap-6 xl:gap-8 items-start justify-center">
    {/* Center Articles Feed - FIRST in DOM for SEO */}
    <div class="w-full xl:flex-1 min-w-0 flex flex-col gap-4 order-1 xl:order-2">
      <SearchablePosts posts={allPosts} client:load />
    </div>

    {/* Left Sidebar - AFTER content in DOM, visually on left via order-1 */}
    <aside
      id="sidebar-left"
      class="w-full xl:w-[260px] shrink-0 flex flex-col gap-4 sm:gap-6 xl:sticky xl:top-[100px] order-2 xl:order-1"
      style="animation-delay: 0.06s"
    >
      <LeftSidebar posts={allPosts} tags={tags} />
    </aside>

    {/* Right Sidebar */}
    <aside
      id="sidebar-right"
      class="w-full xl:w-[260px] shrink-0 flex flex-col gap-4 sm:gap-6 xl:sticky xl:top-[100px] order-3 xl:order-3"
      style="animation-delay: 0.1s"
      transition:name="sidebar-right"
    >
      <PostsTimelineWidget posts={allPosts} />
    </aside>
  </div>
</Layout>
