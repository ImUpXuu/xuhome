---
import { siteConfig } from '../config/site';
import { infoConfig } from '../config/info';
import { seoConfig } from '../config/seo';
import { ClientRouter } from 'astro:transitions';
import NavBar from '../components/NavBar.astro';
import CustomCursor from '../components/CustomCursor.svelte';
import WelcomeToast from '../components/WelcomeToast.astro';
import { PageBanner } from '../components/PageBanner';
import { execSync } from 'child_process';
import '../index.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  categoryName?: string | null;
  tagName?: string | null;
  post?: { title: string; date: string } | null;
  isTalk?: boolean;
  postsCount?: number;
  isAboutPage?: boolean;
  isArticle?: boolean;
}

const {
  title,
  description,
  image = seoConfig.defaultImage,
  categoryName = null,
  tagName = null,
  post = null,
  isTalk = false,
  postsCount = 0,
  isAboutPage = false,
  isArticle = false,
} = Astro.props;

const pageTitle = title 
  ? `${title}${seoConfig.titleTemplate}` 
  : `${siteConfig.title} - ${siteConfig.subtitle.split(' / ')[0]}`;
const pageDescription = description || seoConfig.defaultDescription;

const sectionTitle = (() => {
  if (isTalk) return '说说';
  if (title === '首页') return '最新文章';
  if (title === '文章归档') return '归档';
  return '';
})();

const canonicalURL = new URL(Astro.url.pathname, "https://upxuu.com").href;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="keywords" content={seoConfig.keywords.join(", ")} />
    <meta name="author" content={siteConfig.author} />
    <meta name="robots" content={seoConfig.robots} />
    <link rel="canonical" href={canonicalURL} />

    {/* Open Graph Tags */}
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content={post ? "article" : "website"} />
    <meta property="og:image" content={image} />
    <meta property="og:site_name" content={siteConfig.title} />
    <meta property="og:locale" content="zh-CN" />
    <meta property="og:url" content={canonicalURL} />
    {post && <meta property="article:published_time" content={post.date} />}
    
    {/* Twitter Card Tags */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={seoConfig.twitter.site} />
    <meta name="twitter:creator" content={seoConfig.twitter.creator} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={image} />

    {/* JSON-LD Structured Data */}
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "WebSite",
          "@id": `${siteConfig.url}/#website`,
          "url": siteConfig.url,
          "name": siteConfig.title,
          "description": siteConfig.description,
          "inLanguage": "zh-CN"
        },
        {
          "@type": "Person",
          "@id": `${siteConfig.url}/#person`,
          "name": siteConfig.author,
          "url": siteConfig.url,
          "image": siteConfig.avatar,
          "sameAs": [
            siteConfig.socials.github
          ]
        },
        ...(post ? [{
          "@type": "Article",
          "@id": `${canonicalURL}#article`,
          "headline": post.title,
          "description": pageDescription,
          "image": image,
          "datePublished": post.date,
          "author": {
            "@type": "Person",
            "name": siteConfig.author,
            "url": siteConfig.url,
            "image": siteConfig.avatar
          },
          "publisher": {
            "@type": "Person",
            "name": siteConfig.author,
            "image": siteConfig.avatar
          },
          "mainEntityOfPage": {
            "@type": "WebPage",
            "@id": canonicalURL
          }
        }] : [])
      ]
    })} />

    {/* Dynamic Prefetch & Preconnect */}
    {seoConfig.dnsPrefetch.map(domain => (
      <link rel="dns-prefetch" href={domain} />
    ))}
    {seoConfig.preconnect.map(conn => (
      <link rel="preconnect" href={conn.url} crossorigin={conn.crossOrigin === "anonymous" ? "anonymous" : undefined} />
    ))}

    <script defer src="https://stats.upxuu.com/script.js" data-website-id="cd983d6c-e011-489d-903f-4757ce41c14d"></script>
    <script defer src="https://cloud.umami.is/script.js" data-website-id="9f42cc31-08eb-4829-8af7-06527a02f6c9"></script>
  <style is:global>
    @keyframes content-in {
      0% { opacity: 0; transform: translateY(20px); filter: blur(4px); }
      100% { opacity: 1; transform: translateY(0); filter: blur(0); }
    }
    @keyframes content-out {
      0% { opacity: 1; transform: translateY(0); }
      100% { opacity: 0; transform: translateY(15px); filter: blur(2px); }
    }
    /* Card Specific Entrance - Used for staggered listing */
    @keyframes card-entrance {
      0% { 
        opacity: 0; 
        transform: translateY(30px) scale(0.96); 
        filter: blur(4px);
      }
      70% {
        opacity: 1;
        transform: translateY(-4px) scale(1.02);
        filter: blur(0);
      }
      100% { 
        opacity: 1; 
        transform: translateY(0) scale(1); 
        filter: blur(0);
      }
    }
    .animate-card-entrance {
      animation: card-entrance 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
    }


  </style>
  {/* Dark mode init - default light, never follow system */}
  <script is:inline>
    (function() {
      if (localStorage.getItem('theme') === 'dark') {
        document.documentElement.classList.add('dark');
      }
    })();
  </script>
  <ClientRouter />
</head>
  <body class="bg-[#faf8f5] dark:bg-slate-900 text-slate-800 dark:text-slate-200 selection:bg-[#fde68a] selection:text-[#0284c7]">
    <!-- Skip to content for keyboard users -->
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-[200] focus:bg-[#0284c7] focus:text-white focus:px-4 focus:py-2 focus:rounded-sm focus:font-black focus:text-sm focus:shadow-[4px_4px_0px_0px_#fde68a] focus:no-underline focus:outline-none">
      跳转到主要内容
    </a>
    {/* Global reading progress bar */}
    <div class="fixed top-0 left-0 w-full h-[5px] bg-transparent z-[110] pointer-events-none">
      <div 
        id="scroll-bar-indicator"
        class="h-full bg-gradient-to-r from-[#0284c7] via-[#0ea5e9] to-[#f59e0b] origin-left w-0 transition-all duration-75"
      ></div>
    </div>
    {/* Page navigation loading bar */}
    <div id="nav-loader" class="fixed top-0 left-0 w-full h-[4px] z-[111] pointer-events-none hidden">
      <div class="h-full bg-gradient-to-r from-[#fde68a] via-[#f59e0b] to-[#fde68a] w-0 h-full transition-all duration-300"></div>
    </div>
    {/* Bottom page transition progress bar */}
    <div id="bottom-loader" class="fixed bottom-0 left-0 w-full z-[111] pointer-events-none" style="transform: translateY(100%); transition: transform 0.3s ease;">
      <div class="h-[5px] bg-[#0284c7] border-t-2 border-[#0284c7] shadow-[0px_-2px_0px_0px_#f59e0b] w-0" style="transition: width 0.3s ease-out;"></div>
    </div>
    <CustomCursor client:load />
    <WelcomeToast />                
    <div class="flex flex-col min-h-screen">
      <NavBar />
      
      {!isAboutPage ? (
        <div 
          class="min-h-screen bg-[#faf8f5] dark:bg-slate-900 py-2 px-2 sm:py-6 sm:px-6 md:py-8 md:px-8 font-sans transition-all duration-300"
          style={{ backgroundImage: "radial-gradient(#0284c70d 2px, transparent 2px)", backgroundSize: "24px 24px" }}
        >
          <div class="max-w-[1440px] w-full mx-auto flex flex-col gap-3 sm:gap-6">
            <PageBanner 
              client:load
              pathname={Astro.url.pathname}
              categoryName={categoryName}
              tagName={tagName}
              post={post}
              postsCount={postsCount}
            />
            {sectionTitle && (
              <div class="flex items-center gap-3 px-1 select-none">
                <span class="w-3 h-3 bg-[#f59e0b] border-2 border-[#0284c7] rotate-45 shrink-0"></span>
                <h2 class="text-sm sm:text-base font-black text-[#0284c7] tracking-widest uppercase">
                  {sectionTitle}
                </h2>
                {postsCount > 0 && (
                  <span class="text-[10px] font-black text-slate-400 font-mono">({postsCount})</span>
                )}
              </div>
            )}
            <main
              id="main-content"
              class="flex-1"
              transition:animate={{
                forwards: {
                  old: [{ name: 'content-out', duration: '0.2s', easing: 'ease-in' }],
                  new: [{ name: 'content-in', duration: '0.35s', easing: 'ease-out' }]
                },
                backwards: {
                  old: [{ name: 'content-out', duration: '0.2s', easing: 'ease-in' }],
                  new: [{ name: 'content-in', duration: '0.35s', easing: 'ease-out' }]
                }
              }}
            >
              <slot />
            </main>
          </div>
        </div>
      ) : (
        <main class="flex-1">
          <slot />
        </main>
      )}
      
      <footer class="w-full bg-[#faf8f5] dark:bg-slate-900 border-t-4 border-[#0284c7] select-none">
        <div class="max-w-5xl mx-auto px-4 py-5 text-center text-xs font-mono text-slate-500 dark:text-slate-400 leading-relaxed space-y-2">
          <div class="font-bold">
            <span class="text-slate-700 dark:text-slate-300">{infoConfig.footer.copyrightText}</span>
            <span class="mx-1.5">|</span>
            {infoConfig.footer.links.map((link, i) => (
              <>
                <a href={link.path} target={link.external ? "_blank" : undefined} rel={link.external ? "noopener noreferrer" : undefined} class="hover:text-[#0ea5e9] transition-colors hover:underline">{link.name}</a>
                {i < infoConfig.footer.links.length - 1 && <span class="mx-1">·</span>}
              </>
            ))}
            {infoConfig.footer.icp && <><span class="mx-1.5">|</span><a href={infoConfig.footer.icp.link} target="_blank" rel="noopener noreferrer" class="hover:text-[#0ea5e9] transition-colors text-[#0284c7] hover:underline">{infoConfig.footer.icp.text}</a></>}
          </div>
          <div>
            <span>本站已开源 </span><a href="https://github.com/ImUpXuu/xuhome" class="hover:text-[#0ea5e9] underline font-bold">IMUPXUU/XUHOME</a>
            {(() => {
              try {
                const log = execSync('git log -n 1 --pretty=format:"%h||%s||%ci"').toString().trim();
                const [hash, ...rest] = log.split('||');
                const message = rest.join(' ').split('||')[0];
                const date = rest.join(' ').split('||')[1] || '';
                const formattedDate = date ? new Date(date).toLocaleDateString('zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit', hour: '2-digit', minute: '2-digit' }) : '';
                return <>
                  <span class="mx-1">·</span>
                  <span class="font-bold">LATEST COMMIT</span>
                  <span class="mx-1">-</span>
                  <a href={`https://github.com/ImUpXuu/xuhome/commit/${hash}`} class="hover:text-[#0ea5e9] underline">{hash}</a>
                  <span class="mx-1">·</span>
                  <span>{formattedDate}</span>
                  <span class="mx-1">·</span>
                  <span>{message}</span>
                </>;
              } catch (e) {
                console.warn('[Layout] Git info unavailable at build time');
                return <span class="text-slate-400">—</span>;
              }
            })()}
          </div>
          <div id="footer-stats" class="text-[10px] sm:text-xs">
            <span>访问量 <span id="stat-pv" class="font-bold text-[#0284c7]">-</span></span>
            <span class="mx-1">|</span>
            <span>访客 <span id="stat-uv" class="font-bold text-[#0284c7]">-</span></span>
            <span class="mx-1">|</span>
            <span>次数 <span id="stat-vt" class="font-bold text-[#0284c7]">-</span></span>
            <span class="mx-1">|</span>
            <span>在线 <span id="stat-online" class="font-bold text-[#10b981]">-</span></span>
          </div>
          <div id="footer-uptime" class="text-[10px] sm:text-xs text-slate-400 dark:text-slate-500">
            本站已在互联网中航行 <span id="uptime-display" class="font-bold text-[#0284c7]">计算中...</span>
          </div>
          <div id="footer-perf" class="text-[10px] sm:text-xs text-slate-400 dark:text-slate-500">
            <span>加载 <span id="perf-time" class="font-bold text-[#0284c7]">-</span></span>
            <span class="mx-1">·</span>
            <span>传输 <span id="perf-size" class="font-bold text-[#0284c7]">-</span></span>
          </div>
        </div>
      </footer>
    </div>

<script>
  function initFooter() {
    (async function() {
      try {
        const [statsRes, activeRes] = await Promise.allSettled([
          fetch('https://vapi.upxuu.com/statsapi/alltime'),
          fetch('https://vapi.upxuu.com/api/active')
        ]);
        let pv = 0, uv = 0, vt = 0, active = 0;
        if (statsRes.status === 'fulfilled') {
          const d = await statsRes.value.json();
          pv = typeof d.pageviews === 'object' ? (d.pageviews?.value ?? 0) : (d.pageviews ?? 0);
          uv = typeof d.visitors === 'object' ? (d.visitors?.value ?? 0) : (d.visitors ?? 0);
          vt = typeof d.visits === 'object' ? (d.visits?.value ?? 0) : (d.visits ?? 0);
        }
        if (activeRes.status === 'fulfilled') {
          const d = await activeRes.value.json();
          active = Array.isArray(d) ? d.length : (d.total ?? d.visitors ?? 0);
        }
        const pvEl = document.getElementById('stat-pv');
        if (pvEl) pvEl.textContent = pv.toLocaleString();
        const uvEl = document.getElementById('stat-uv');
        if (uvEl) uvEl.textContent = uv.toLocaleString();
        const vtEl = document.getElementById('stat-vt');
        if (vtEl) vtEl.textContent = vt.toLocaleString();
        const olEl = document.getElementById('stat-online');
        if (olEl) olEl.textContent = String(active);
      } catch {}
    })();
  }

  // Show real page performance metrics (load time + transfer size)
  function showPerfMetrics() {
    try {
      const nav = performance.getEntriesByType('navigation')[0];
      if (!nav) return;
      const loadTime = (nav.loadEventEnd - nav.fetchStart) / 1000; // seconds
      const transferSize = nav.transferSize || 0; // bytes

      const timeEl = document.getElementById('perf-time');
      if (timeEl) {
        timeEl.textContent = loadTime > 0 ? loadTime.toFixed(2) + 's' : '-';
      }
      const sizeEl = document.getElementById('perf-size');
      if (sizeEl) {
        if (transferSize > 1048576) {
          sizeEl.textContent = (transferSize / 1048576).toFixed(1) + ' MB';
        } else if (transferSize > 1024) {
          sizeEl.textContent = (transferSize / 1024).toFixed(0) + ' KB';
        } else {
          sizeEl.textContent = transferSize + ' B';
        }
      }
    } catch {}
  }

  // Initial perf measurement
  if (document.readyState === 'complete') {
    showPerfMetrics();
  } else {
    window.addEventListener('load', showPerfMetrics);
  }

  if (!window._uptimeStarted) {
    window._uptimeStarted = true;
    const start = new Date(2025, 8, 30, 20, 20, 0);
    setInterval(function() {
      const el = document.getElementById('uptime-display');
      if (!el) return;
      const diff = (Date.now() - start.getTime()) / 1000;
      const days = Math.floor(diff / 86400);
      const hours = Math.floor((diff % 86400) / 3600);
      const mins = Math.floor((diff % 3600) / 60);
      const secs = diff % 60;
      el.textContent = days + '\u5929' + String(hours).padStart(2,'0') + '\u5c0f\u65f6' + String(mins).padStart(2,'0') + '\u5206' + secs.toFixed(2).padStart(5,'0') + '\u79d2';
    }, 10);
  }

  document.addEventListener('astro:page-load', () => {
    initFooter();
    showPerfMetrics();
  });
</script>
    </div>

    {/* Floating Back To Top button */}
    <button
      id="back-to-top-btn"
      class="fixed bottom-24 right-6 z-[95] w-12 h-12 rounded-sm border-3 sm:border-4 border-[#0284c7] bg-[#fde68a] dark:bg-[#1e293b] text-[#0284c7] flex items-center justify-center cursor-pointer shadow-[4px_4px_0px_0px_#0284c7] hover:-translate-y-1 hover:shadow-[6px_6px_0px_0px_#0284c7] active:translate-y-0 active:shadow-none transition-all duration-150 opacity-0 pointer-events-none"
      aria-label="回到顶部"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 stroke-[3]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 10l7-7m0 0l7 7m-7-7v18" />
      </svg>
    </button>
  </body>
</html>

<script is:inline data-astro-rerun>
{
  function setupGlobalScrollBar() {
    const indicator = document.getElementById('scroll-bar-indicator');
    if (indicator) {
      window.addEventListener('scroll', () => {
        const totalHeight = document.documentElement.scrollHeight - window.innerHeight;
        const percentage = totalHeight > 0 ? (window.pageYOffset / totalHeight) * 100 : 0;
        indicator.style.width = percentage + '%';
      }, { passive: true });
    }
  }

  function setupBackToTop() {
    // Floating Back to Top Button script
    const backToTopBtn = document.getElementById('back-to-top-btn');
    if (backToTopBtn) {
      window.addEventListener('scroll', () => {
        if (window.scrollY > 300) {
          backToTopBtn.classList.remove('opacity-0', 'pointer-events-none');
          backToTopBtn.classList.add('opacity-100');
        } else {
          backToTopBtn.classList.add('opacity-0', 'pointer-events-none');
          backToTopBtn.classList.remove('opacity-100');
        }
      }, { passive: true });

      backToTopBtn.addEventListener('click', () => {
        window.scrollTo({
          top: 0,
          behavior: 'smooth'
        });
      });
    }
  }

  // Initial run
  setupGlobalScrollBar();
  setupBackToTop();
  
  // Page navigation loader — tracks real resource loading
  let navLoaderTimer = null;
  let bottomLoaderTimer = null;
  const navLoader = document.getElementById('nav-loader');
  const navLoaderBar = navLoader?.querySelector('div');
  const bottomLoader = document.getElementById('bottom-loader');
  const bottomLoaderBar = bottomLoader?.querySelector('div');

  // PerformanceObserver-based real resource tracking
  let resourceObserver = null;
  let navStartTime = 0;
  let pendingResources = new Set();
  let loadedCount = 0;
  let totalCount = 0;
  let loaderActive = false;

  function setProgress(pct) {
    const clamped = Math.max(0, Math.min(100, pct));
    // Top loader
    if (navLoaderBar) {
      navLoaderBar.style.width = clamped + '%';
    }
    // Bottom loader: reflect same real progress
    if (bottomLoaderBar) {
      bottomLoaderBar.style.width = clamped + '%';
    }
  }

  function startResourceTracking() {
    if (resourceObserver) {
      resourceObserver.disconnect();
    }
    navStartTime = performance.now();
    pendingResources = new Set();
    loadedCount = 0;
    totalCount = 0;
    setProgress(0);

    try {
      resourceObserver = new PerformanceObserver((list) => {
        if (!loaderActive) return;
        for (const entry of list.getEntries()) {
          // Only track resources loaded AFTER navigation started
          if (entry.startTime < navStartTime) continue;
          // Only track meaningful resources
          if (entry.initiatorType === 'fetch' || entry.initiatorType === 'xmlhttprequest') continue;
          const key = entry.name;
          if (!pendingResources.has(key)) {
            pendingResources.add(key);
            totalCount++;
          }
          // transferSize can be 0 for cached/304 — count as loaded instantly
          if (entry.transferSize > 0 || entry.duration > 0) {
            if (pendingResources.has(key)) {
              pendingResources.delete(key);
              loadedCount++;
            }
          }
        }
        // Calculate real progress (reserve 5%-95% range while loading)
        // Cached resources are counted as loaded instantly
        const remaining = pendingResources.size;
        if (totalCount > 0) {
          const realPct = Math.round((loadedCount / totalCount) * 90); // 0-90% for resources
          setProgress(5 + realPct); // Start at 5%, resource loading covers 5%-95%
        } else {
          // No resources detected yet, show 10%
          setProgress(10);
        }
      });
      resourceObserver.observe({ type: 'resource', buffered: false });
    } catch (e) {
      // PerformanceObserver not supported — fall through to fake progress
    }

    // Also track document readiness
    loaderActive = true;
  }

  function startNavLoader() {
    if (navLoader && navLoaderBar) {
      clearTimeout(navLoaderTimer);
      navLoader.classList.remove('hidden');
      navLoaderBar.style.transition = 'width 0.3s ease-out';
    }

    // Bottom loader: slide up
    if (bottomLoader && bottomLoaderBar) {
      clearTimeout(bottomLoaderTimer);
      bottomLoader.style.transform = 'translateY(0)';
      bottomLoaderBar.style.width = '0%';
      bottomLoaderBar.style.transition = 'width 0.3s ease-out';
    }

    setProgress(3);
    startResourceTracking();

    // Fallback timer: if no resources are detected within 2s, simulate steady progress
    clearTimeout(window.__loaderFallbackTimer);
    window.__loaderFallbackTimer = setTimeout(() => {
      if (!loaderActive) return;
      if (totalCount === 0) {
        // No resources detected — simulate incremental progress up to 85%
        let fakeProgress = 10;
        window.__loaderFallbackInterval = setInterval(() => {
          if (!loaderActive) {
            clearInterval(window.__loaderFallbackInterval);
            return;
          }
          fakeProgress += Math.random() * 8 + 2;
          if (fakeProgress >= 85) {
            fakeProgress = 85;
            clearInterval(window.__loaderFallbackInterval);
          }
          setProgress(fakeProgress);
        }, 400);
      }
    }, 2000);
  }

  function completeNavLoader() {
    loaderActive = false;
    clearTimeout(window.__loaderFallbackTimer);
    clearInterval(window.__loaderFallbackInterval);

    if (resourceObserver) {
      resourceObserver.disconnect();
      resourceObserver = null;
    }

    // Jump to 100%
    if (navLoaderBar) setProgress(100);
    if (bottomLoaderBar) setProgress(100);

    if (navLoader && navLoaderBar) {
      clearTimeout(navLoaderTimer);
      navLoaderBar.style.transition = 'width 0.2s ease-out';
      navLoaderBar.style.width = '100%';
      navLoaderTimer = setTimeout(() => {
        navLoader.classList.add('hidden');
        navLoaderBar.style.width = '0%';
      }, 300);
    }

    // Bottom loader: finish then slide down
    if (bottomLoader && bottomLoaderBar) {
      clearTimeout(bottomLoaderTimer);
      bottomLoaderBar.style.transition = 'width 0.2s ease-out';
      bottomLoaderBar.style.width = '100%';
      bottomLoaderTimer = setTimeout(() => {
        bottomLoader.style.transform = 'translateY(100%)';
        setTimeout(() => {
          bottomLoaderBar.style.width = '0%';
        }, 300);
      }, 250);
    }
  }

  if (!window._layoutListenersInited) {
    document.addEventListener('astro:before-preparation', startNavLoader);
    document.addEventListener('astro:error', completeNavLoader);
    document.addEventListener('astro:page-load', () => {
      completeNavLoader();
      setupGlobalScrollBar();
      setupBackToTop();
      showPerfMetrics();
      if (localStorage.getItem('theme') === 'dark') {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }
    });
    window._layoutListenersInited = true;
  }
}
</script>

<!-- External link confirmation popover -->
<script>
  (function() {
    const SITE_HOST = 'upxuu.com';
    const TRUSTED = ['github.com', 'bilibili.com', 'space.bilibili.com', 'icp.gov.moe'];
    let popover = null;
    let countdownTimer = null;
    let pendingUrl = '';

    function isExternal(href) {
      if (!href || href.startsWith('#') || href.startsWith('javascript:') || href.startsWith('mailto:')) return false;
      if (href.startsWith('/') && !href.startsWith('//')) return false;
      try {
        const u = new URL(href, location.origin);
        return u.hostname !== SITE_HOST && !u.hostname.endsWith('.' + SITE_HOST);
      } catch { return false; }
    }

    function isTrustedDomain(href) {
      try {
        const host = new URL(href, location.origin).hostname;
        return TRUSTED.some(d => host === d || host.endsWith('.' + d));
      } catch { return false; }
    }

    function isBypassed(anchor) {
      if (anchor.closest('[data-ext-bypass]')) return true;
      if (isTrustedDomain(anchor.getAttribute('href'))) return true;
      return false;
    }

    function createPopover() {
      if (popover) return popover;
      const el = document.createElement('div');
      el.id = 'ext-link-popover';
      el.className = 'fixed z-[3000] bg-white dark:bg-slate-800 border-3 border-[#0284c7] shadow-[4px_4px_0px_0px_#0284c7] rounded-sm p-4';
      el.style.maxWidth = '340px';
      el.style.opacity = '0';
      el.style.pointerEvents = 'none';
      el.style.transform = 'translateY(8px) scale(0.95)';
      el.style.transition = 'opacity 0.2s ease, transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1)';
      el.innerHTML = `
        <div class="flex items-start gap-2 mb-3">
          <span class="text-lg shrink-0">⚠️</span>
          <div>
            <p class="text-xs font-black text-[#0284c7] uppercase tracking-wider leading-snug">你即将跳转至第三方页面</p>
            <p class="text-[10px] text-slate-400 dark:text-slate-500 mt-0.5 leading-snug">本站不保证该站内容合规与安全</p>
          </div>
        </div>
        <div class="text-[10px] font-mono text-slate-500 dark:text-slate-400 mb-3 py-1.5 px-2 bg-slate-100 dark:bg-slate-700 rounded-sm break-all leading-relaxed border-l-2 border-[#f59e0b]" id="ext-link-url"></div>
        <div class="flex items-center gap-2">
          <button id="ext-link-yes" class="flex-1 bg-[#0284c7] text-white font-black py-1.5 border-2 border-[#0284c7] rounded-sm text-xs uppercase tracking-wider shadow-[2px_2px_0px_0px_#f59e0b] hover:shadow-none hover:translate-x-0.5 hover:translate-y-0.5 transition-all cursor-pointer">是，打开</button>
          <button id="ext-link-no" class="flex-1 bg-white dark:bg-slate-700 text-[#0284c7] font-black py-1.5 border-2 border-[#0284c7] rounded-sm text-xs uppercase tracking-wider shadow-[2px_2px_0px_0px_#0284c7] hover:shadow-none hover:translate-x-0.5 hover:translate-y-0.5 transition-all cursor-pointer relative overflow-hidden">
            <span id="ext-link-no-text">否</span>
            <span id="ext-link-countdown" class="hidden absolute inset-0 flex items-center justify-center font-mono font-black text-[#f59e0b] text-sm bg-white dark:bg-slate-700">3</span>
          </button>
        </div>
      `;
      document.body.appendChild(el);

      // "是" — open link via trusted anchor element (avoids popup blocker)
      el.querySelector('#ext-link-yes').addEventListener('click', () => {
        if (pendingUrl) {
          const a = document.createElement('a');
          a.href = pendingUrl;
          a.target = '_blank';
          a.rel = 'noopener noreferrer';
          a.click();
        }
        dismiss();
      });
      // "否" — start countdown
      el.querySelector('#ext-link-no').addEventListener('click', startCountdown);

      // Click outside to dismiss (bubble phase)
      document.addEventListener('click', function(e) {
        if (!popover) return;
        if (popover.style.pointerEvents === 'none') return;
        if (!popover.contains(e.target)) dismiss();
      });

      popover = el;
      return el;
    }

    function positionPopover(anchor) {
      const rect = anchor.getBoundingClientRect();
      const po = createPopover();
      const pw = 340;
      let left = rect.left;
      let top = rect.bottom + 8;
      if (left + pw > window.innerWidth - 8) left = window.innerWidth - pw - 8;
      if (left < 8) left = 8;
      if (top + 160 > window.innerHeight) top = rect.top - 168;
      po.style.left = left + 'px';
      po.style.top = top + 'px';
    }

    function show(anchor, url) {
      pendingUrl = url;
      clearCountdown();
      const po = createPopover();
      po.querySelector('#ext-link-url').textContent = url;
      po.querySelector('#ext-link-no-text').classList.remove('invisible');
      po.querySelector('#ext-link-countdown').classList.add('hidden');
      positionPopover(anchor);
      // Trigger entrance animation
      requestAnimationFrame(() => {
        po.style.opacity = '1';
        po.style.pointerEvents = 'auto';
        po.style.transform = 'translateY(0) scale(1)';
      });
    }

    function dismiss() {
      clearCountdown();
      pendingUrl = '';
      if (!popover) return;
      popover.style.opacity = '0';
      popover.style.pointerEvents = 'none';
      popover.style.transform = 'translateY(8px) scale(0.95)';
    }

    function startCountdown() {
      let sec = 3;
      var noText = popover.querySelector('#ext-link-no-text');
      var cdEl = popover.querySelector('#ext-link-countdown');
      noText.classList.add('invisible');
      cdEl.classList.remove('hidden');
      cdEl.textContent = sec;

      clearCountdown();
      countdownTimer = setInterval(function() {
        sec--;
        if (sec <= 0) {
          clearInterval(countdownTimer);
          countdownTimer = null;
          dismiss();
        } else {
          cdEl.textContent = sec;
        }
      }, 1000);
    }

    function clearCountdown() {
      if (countdownTimer) { clearInterval(countdownTimer); countdownTimer = null; }
    }

    // Intercept external link clicks (capture phase)
    document.addEventListener('click', function(e) {
      var anchor = e.target.closest('a');
      if (!anchor) return;
      var href = anchor.getAttribute('href');
      if (!isExternal(href)) return;
      if (isBypassed(anchor)) return;
      e.preventDefault();
      e.stopPropagation();
      show(anchor, href);
    }, true);

    document.addEventListener('astro:page-load', dismiss);
    document.addEventListener('astro:before-preparation', dismiss);
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && popover && popover.style.pointerEvents === 'auto') dismiss();
    });
  })();
</script>
