---
import { siteConfig, footerConfig } from '../config/site';
import { infoConfig } from '../config/info';
import { seoConfig } from '../config/seo';
import { ClientRouter } from 'astro:transitions';
import NavBar from '../components/NavBar.astro';
import CustomCursor from '../components/CustomCursor.svelte';
import WelcomeToast from '../components/WelcomeToast.astro';
import { PageBanner } from '../components/PageBanner';
import { execSync } from 'child_process';
import '../index.css';

let bgCount = 4;

interface Props {
  title?: string;
  description?: string;
  image?: string;
  categoryName?: string | null;
  tagName?: string | null;
  post?: { title: string; date: string } | null;
  isTalk?: boolean;
  postsCount?: number;
  isAboutPage?: boolean;
  isArticle?: boolean;
}

const {
  title,
  description,
  image = seoConfig.defaultImage,
  categoryName = null,
  tagName = null,
  post = null,
  isTalk = false,
  postsCount = 0,
  isAboutPage = false,
  isArticle = false,
} = Astro.props;

const pageTitle = title 
  ? `${title}${seoConfig.titleTemplate}` 
  : `${siteConfig.title} - ${siteConfig.subtitle.split(' / ')[0]}`;
const pageDescription = (description || seoConfig.defaultDescription).length < 10 
  ? seoConfig.defaultDescription 
  : (description || seoConfig.defaultDescription);

const canonicalURL = new URL(Astro.url.pathname, siteConfig.url).href;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="keywords" content={seoConfig.keywords.join(", ")} />
    <meta name="author" content={siteConfig.author} />
    <meta name="robots" content={seoConfig.robots} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="msvalidate.01" content="8814B55DAA53801F47B998FE06421544" />
    {/* Favicon - use avatar image */}
    <link rel="icon" href={siteConfig.avatar} />
    <link rel="apple-touch-icon" href={siteConfig.avatar} />

    {/* Open Graph Tags */}
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content={post ? "article" : "website"} />
    <meta property="og:image" content={image} />
    <meta property="og:site_name" content={siteConfig.title} />
    <meta property="og:locale" content="zh-CN" />
    <meta property="og:url" content={canonicalURL} />
    {post && <meta property="article:published_time" content={post.dateISO || post.date} />}
    
    {/* Twitter Card Tags */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={seoConfig.twitter.site} />
    <meta name="twitter:creator" content={seoConfig.twitter.creator} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={image} />

    {/* JSON-LD Structured Data */}
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "WebSite",
          "@id": `${siteConfig.url}/#website`,
          "url": siteConfig.url,
          "name": siteConfig.title,
          "description": siteConfig.description,
          "inLanguage": "zh-CN"
        },
        {
          "@type": "Person",
          "@id": `${siteConfig.url}/#person`,
          "name": siteConfig.author,
          "url": siteConfig.url,
          "image": siteConfig.avatar,
          "sameAs": [
            siteConfig.socials.github
          ]
        },
        ...(post ? [{
          "@type": "Article",
          "@id": `${canonicalURL}#article`,
          "headline": post.title,
          "description": pageDescription,
          "image": image,
          "datePublished": post.dateISO || post.date,
          "author": {
            "@type": "Person",
            "name": siteConfig.author,
            "url": siteConfig.url,
            "image": siteConfig.avatar
          },
          "publisher": {
            "@type": "Person",
            "name": siteConfig.author,
            "image": siteConfig.avatar
          },
          "mainEntityOfPage": {
            "@type": "WebPage",
            "@id": canonicalURL
          }
        }] : [])
      ]
    })} />

    {/* Dynamic Prefetch & Preconnect */}
    {seoConfig.dnsPrefetch.map(domain => (
      <link rel="dns-prefetch" href={domain} />
    ))}
    {seoConfig.preconnect.map(conn => (
      <link rel="preconnect" href={conn.url} crossorigin={conn.crossOrigin === "anonymous" ? "anonymous" : undefined} />
    ))}

    {siteConfig.analytics.umami.map(u => (
      <script defer src={u.src} data-website-id={u.id}></script>
    ))}
  <style is:global>
    @keyframes content-in {
      0% { opacity: 0; transform: translateY(20px); filter: blur(4px); }
      100% { opacity: 1; transform: translateY(0); filter: blur(0); }
    }
    @keyframes content-out {
      0% { opacity: 1; transform: translateY(0); }
      100% { opacity: 0; transform: translateY(15px); filter: blur(2px); }
    }
    /* Card Specific Entrance - Used for staggered listing */
    @keyframes card-entrance {
      0% { 
        opacity: 0; 
        transform: translateY(30px) scale(0.96); 
        filter: blur(4px);
      }
      70% {
        opacity: 1;
        transform: translateY(-4px) scale(1.02);
        filter: blur(0);
      }
      100% { 
        opacity: 1; 
        transform: translateY(0) scale(1); 
        filter: blur(0);
      }
    }
    .animate-card-entrance {
      animation: card-entrance 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
    }




  </style>
  {/* Dark mode init: read persisted theme before first paint */}
  <script is:inline>
    (function() {
      try {
        const saved = localStorage.getItem('theme');
        if (saved === 'dark') {
          document.documentElement.classList.add('dark');
        } else if (saved === 'light') {
          document.documentElement.classList.remove('dark');
        }
      } catch (e) {
        // localStorage may be unavailable in some contexts
      }
    })();
  </script>
  <ClientRouter />
</head>
  <body data-bg-count={bgCount} class="dark:bg-slate-900 text-slate-900 dark:text-slate-100 selection:bg-[#fde68a] selection:text-[#0284c7]">
    {/* Persistent full-page bg layer (survives View Transitions) */}
    <div
      id="site-bg"
      transition:persist="site-bg"
      class="fixed inset-0 -z-10 pointer-events-none"
      aria-hidden="true"
    ></div>
    <!-- Skip to content for keyboard users -->
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-[200] focus:bg-[#0284c7] focus:text-white focus:px-4 focus:py-2 focus:rounded-sm focus:font-black focus:text-sm focus:shadow-[4px_4px_0px_0px_#fde68a] focus:no-underline focus:outline-none">
      跳转到主要内容
    </a>
    {/* Global reading progress bar */}
    <div class="fixed top-0 left-0 w-full h-[5px] bg-transparent z-[110] pointer-events-none">
      <div 
        id="scroll-bar-indicator"
        class="h-full bg-gradient-to-r from-[#0284c7] via-[#0ea5e9] to-[#f59e0b] origin-left w-0 transition-all duration-75"
      ></div>
    </div>
    {/* Page navigation loading bar */}
    <div id="nav-loader" class="fixed top-0 left-0 w-full h-[4px] z-[111] pointer-events-none hidden">
      <div class="h-full bg-gradient-to-r from-[#fde68a] via-[#f59e0b] to-[#fde68a] w-0 h-full transition-all duration-300"></div>
    </div>
    {/* Bottom page transition progress bar */}
    <div id="bottom-loader" class="fixed bottom-0 left-0 w-full z-[111] pointer-events-none" style="transform: translateY(100%); transition: transform 0.3s ease;">
      <div class="h-[5px] bg-[#0284c7] border-t-2 border-[#0284c7] shadow-[0px_-2px_0px_0px_#f59e0b] w-0" style="transition: width 0.3s ease-out;"></div>
    </div>
    <CustomCursor client:load />
    <WelcomeToast />                
    <div class="flex flex-col min-h-screen">
      <NavBar />
      
      {!isAboutPage ? (
        <div 
          class="min-h-screen dark:bg-slate-900 py-2 px-2 sm:py-6 sm:px-6 md:py-8 md:px-8 font-sans transition-all duration-300"
          style={{ backgroundImage: "radial-gradient(#0284c70d 2px, transparent 2px)", backgroundSize: "24px 24px" }}
        >
          <div class="max-w-[1440px] w-full mx-auto flex flex-col gap-3 sm:gap-6">
            <PageBanner 
              client:load
              pathname={Astro.url.pathname}
              categoryName={categoryName}
              tagName={tagName}
              post={post}
              postsCount={postsCount}
            />

            <main
              id="main-content"
              class="flex-1"
              transition:animate={{
                forwards: {
                  old: [{ name: 'content-out', duration: '0.2s', easing: 'ease-in' }],
                  new: [{ name: 'content-in', duration: '0.35s', easing: 'ease-out' }]
                },
                backwards: {
                  old: [{ name: 'content-out', duration: '0.2s', easing: 'ease-in' }],
                  new: [{ name: 'content-in', duration: '0.35s', easing: 'ease-out' }]
                }
              }}
            >
              <slot />
            </main>
          </div>
        </div>
      ) : (
        <main class="flex-1">
          <slot />
        </main>
      )}
      
      <footer class="w-full dark:bg-slate-900 border-t-4 border-[#0284c7] select-none">
        <div class="max-w-5xl mx-auto px-4 py-5 text-center text-xs font-mono text-slate-500 dark:text-slate-400 leading-relaxed space-y-2">
          <div class="font-bold text-green-500 text-[11px] sm:text-xs">
            唯一正版域名 <a href="https://upxuu.com" class="underline font-black hover:text-green-600">UPXUU.COM</a>
          </div>
          <div class="font-bold">
            <span class="text-slate-700 dark:text-slate-300">{infoConfig.footer.copyrightText}</span>
            <span class="mx-1.5">|</span>
            {infoConfig.footer.links.map((link, i) => (
              <>
                <a href={link.path} target={link.external ? "_blank" : undefined} rel={link.external ? "noopener noreferrer" : undefined} class="hover:text-[#0ea5e9] transition-colors hover:underline">{link.name}</a>
                {i < infoConfig.footer.links.length - 1 && <span class="mx-1">·</span>}
              </>
            ))}
            {infoConfig.footer.icp && <><span class="mx-1.5">|</span><a href={infoConfig.footer.icp.link} target="_blank" rel="noopener noreferrer" class="hover:text-[#0ea5e9] transition-colors text-[#0284c7] hover:underline">{infoConfig.footer.icp.text}</a></>}
          </div>
          <div>
            <span>{footerConfig.repoText}</span><a href={footerConfig.repoUrl} class="hover:text-[#0ea5e9] underline font-bold">{footerConfig.repoDisplayName}</a>
            {(() => {
              try {
                const log = execSync('git log -n 1 --pretty=format:"%h||%s||%ci"').toString().trim();
                const [hash, ...rest] = log.split('||');
                const message = rest.join(' ').split('||')[0];
                const date = rest.join(' ').split('||')[1] || '';
                const formattedDate = date ? new Date(date).toLocaleDateString('zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit', hour: '2-digit', minute: '2-digit' }) : '';
                return <>
                  <span class="mx-1">·</span>
                  <span class="font-bold">LATEST COMMIT</span>
                  <span class="mx-1">-</span>
                  <a href={`${footerConfig.repoUrl}/commit/${hash}`} class="hover:text-[#0ea5e9] underline">{hash}</a>
                  <span class="mx-1">·</span>
                  <span>{formattedDate}</span>
                  <span class="mx-1">·</span>
                  <span>{message}</span>
                </>;
              } catch (e) {
                console.warn('[Layout] Git info unavailable at build time');
                return <span class="text-slate-400">—</span>;
              }
            })()}
          </div>
          <div id="footer-stats" class="text-[10px] sm:text-xs">
            <span>访问量 <span id="stat-pv" class="font-bold text-[#0284c7]">-</span></span>
            <span class="mx-1">|</span>
            <span>访客 <span id="stat-uv" class="font-bold text-[#0284c7]">-</span></span>
            <span class="mx-1">|</span>
            <span>次数 <span id="stat-vt" class="font-bold text-[#0284c7]">-</span></span>
            <span class="mx-1">|</span>
            <span>在线 <span id="stat-online" class="font-bold text-[#10b981]">-</span></span>
          </div>
          <div id="footer-uptime" class="text-[10px] sm:text-xs text-slate-400 dark:text-slate-500">
            本站已在互联网中航行 <span id="uptime-display" class="font-bold text-[#0284c7]">计算中...</span>
          </div>
          <div id="footer-perf" class="text-[10px] sm:text-xs text-slate-400 dark:text-slate-500">
            <span>加载 <span id="perf-time" class="font-bold text-[#0284c7]">-</span></span>
            <span class="mx-1">·</span>
            <span>传输 <span id="perf-size" class="font-bold text-[#0284c7]">-</span></span>
          </div>
          <div id="footer-stats-mon" class="text-[10px] sm:text-xs text-slate-400 dark:text-slate-500"></div>
        </div>
      </footer>
    </div>

<script is:inline>
  function initFooter() {
    Promise.allSettled([
      fetch('https://blogapi.476543.xyz/statsapi/alltime', { signal: AbortSignal.timeout(5000) }),
      fetch('https://blogapi.476543.xyz/api/active', { signal: AbortSignal.timeout(5000) })
    ]).then(async ([statsRes, activeRes]) => {
      let pv = 0, uv = 0, vt = 0, active = 0;
      if (statsRes.status === 'fulfilled') {
        try { const d = await statsRes.value.json(); pv = typeof d.pageviews === 'object' ? (d.pageviews?.value ?? 0) : (d.pageviews ?? 0); uv = typeof d.visitors === 'object' ? (d.visitors?.value ?? 0) : (d.visitors ?? 0); vt = typeof d.visits === 'object' ? (d.visits?.value ?? 0) : (d.visits ?? 0); } catch {}
      }
      if (activeRes.status === 'fulfilled') {
        try { const d = await activeRes.value.json(); active = Array.isArray(d) ? d.length : (d.total ?? d.visitors ?? 0); } catch {}
      }
      const pvEl = document.getElementById('stat-pv'); if (pvEl) pvEl.textContent = pv.toLocaleString();
      const uvEl = document.getElementById('stat-uv'); if (uvEl) uvEl.textContent = uv.toLocaleString();
      const vtEl = document.getElementById('stat-vt'); if (vtEl) vtEl.textContent = vt.toLocaleString();
      const olEl = document.getElementById('stat-online'); if (olEl) olEl.textContent = String(active);
    });
  }

  // Show real page performance metrics (load time + transfer size)
  function showPerfMetrics() {
    try {
      const nav = performance.getEntriesByType('navigation')[0];
      if (!nav) return;
      const loadTime = (nav.loadEventEnd - nav.fetchStart) / 1000; // seconds
      const transferSize = nav.transferSize || 0; // bytes

      const timeEl = document.getElementById('perf-time');
      if (timeEl) {
        timeEl.textContent = loadTime > 0 ? loadTime.toFixed(2) + 's' : '-';
      }
      const sizeEl = document.getElementById('perf-size');
      if (sizeEl) {
        if (transferSize > 1048576) {
          sizeEl.textContent = (transferSize / 1048576).toFixed(1) + ' MB';
        } else if (transferSize > 1024) {
          sizeEl.textContent = (transferSize / 1024).toFixed(0) + ' KB';
        } else {
          sizeEl.textContent = transferSize + ' B';
        }
      }
    } catch {}
  }

  // Initial perf measurement
  if (document.readyState === 'complete') {
    showPerfMetrics();
  } else {
    window.addEventListener('load', showPerfMetrics);
  }

  if (!window._uptimeStarted) {
    window._uptimeStarted = true;
    const start = new Date(2025, 8, 30, 20, 20, 0);
    setInterval(function() {
      const el = document.getElementById('uptime-display');
      if (!el) return;
      const diff = (Date.now() - start.getTime()) / 1000;
      const days = Math.floor(diff / 86400);
      const hours = Math.floor((diff % 86400) / 3600);
      const mins = Math.floor((diff % 3600) / 60);
      const secs = diff % 60;
      el.textContent = days + '\u5929' + String(hours).padStart(2,'0') + '\u5c0f\u65f6' + String(mins).padStart(2,'0') + '\u5206' + secs.toFixed(2).padStart(5,'0') + '\u79d2';
    }, 10);
  }

  document.addEventListener('astro:page-load', () => {
    initFooter();
    showPerfMetrics();
  });
</script>
<script is:inline>
  (function () {
    var KEY = 'xuhome-bg-idx';
    var BEAT_SRC = 'https://beat.345696.xyz/beat.js';

    function applySiteBg() {
      var el = document.getElementById('site-bg');
      if (!el) return;
      var bgCount = Number(document.body && document.body.dataset.bgCount) || 0;
      if (bgCount <= 0) return;

      var i = 0;
      try {
        i = parseInt(sessionStorage.getItem(KEY) || '0', 10) || 0;
      } catch (e) {}
      if (i < 1 || i > bgCount) {
        i = Math.floor(Math.random() * bgCount) + 1;
        try { sessionStorage.setItem(KEY, String(i)); } catch (e) {}
      }

      // top → bottom: texture, beige film, photo
      el.style.backgroundImage =
        'radial-gradient(circle, rgba(253,246,227,0.35) 1px, transparent 1px),' +
        'linear-gradient(rgba(250,248,245,0.45), rgba(250,248,245,0.45)),' +
        'url(https://img.476543.xyz/img/2026/7/' + i + '.webp)';
      el.style.backgroundSize = '24px 24px, cover, cover';
      el.style.backgroundPosition = '0 0, center, center';
      el.style.backgroundRepeat = 'repeat, no-repeat, no-repeat';
      el.style.backgroundAttachment = 'fixed, fixed, fixed';
    }

    // Reload beat.js on every page (incl. View Transitions) so PV is recorded
    function loadBeat() {
      // Dedup: skip if already loaded for current path
      if (document.getElementById('beat-script') && window.__xuhomeBeatPath === window.location.pathname) return;
      window.__xuhomeBeatPath = window.location.pathname;
      var old = document.getElementById('beat-script');
      if (old) old.remove();
      var s = document.createElement('script');
      s.id = 'beat-script';
      s.src = BEAT_SRC + (BEAT_SRC.indexOf('?') >= 0 ? '&' : '?') + '_=' + Date.now();
      s.async = true;
      document.head.appendChild(s);
    }

    function onPage() {
      applySiteBg();
      loadBeat();
    }

    onPage();
    if (!window.__xuhomeBgBeatInited) {
      window.__xuhomeBgBeatInited = true;
      document.addEventListener('astro:after-swap', applySiteBg);
      document.addEventListener('astro:page-load', onPage);
    }
  })();
</script>

    {/* Floating Back To Top button */}
    <button
      id="back-to-top-btn"
      class="fixed bottom-24 right-6 z-[95] w-12 h-12 rounded-sm border-3 sm:border-4 border-[#0284c7] bg-[#fde68a] dark:bg-[#1e293b] text-[#0284c7] flex items-center justify-center cursor-pointer shadow-[4px_4px_0px_0px_#0284c7] hover:-translate-y-1 hover:shadow-[6px_6px_0px_0px_#0284c7] active:translate-y-0 active:shadow-none transition-all duration-150 opacity-0 pointer-events-none"
      aria-label="回到顶部"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 stroke-[3]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 10l7-7m0 0l7 7m-7-7v18" />
      </svg>
    </button>
  </body>
</html>

<script is:inline data-astro-rerun>
{

    const indicator = document.getElementById('scroll-bar-indicator');
    if (!indicator || window.__scrollBarSetup) return;
    window.__scrollBarSetup = true;
    window.addEventListener('scroll', () => {
      const totalHeight = document.documentElement.scrollHeight - window.innerHeight;
      const percentage = totalHeight > 0 ? (window.pageYOffset / totalHeight) * 100 : 0;
      indicator.style.width = percentage + '%';
    }, { passive: true });
  }

  function setupBackToTop() {
    const backToTopBtn = document.getElementById('back-to-top-btn');
    if (!backToTopBtn) return;

    // Scroll listener: only once (window persists across view transitions)
    if (!window.__backToTopScrollSetup) {
      window.__backToTopScrollSetup = true;
      window.addEventListener('scroll', () => {
        const btn = document.getElementById('back-to-top-btn');
        if (!btn) return;
        if (window.scrollY > 300) {
          btn.classList.remove('opacity-0', 'pointer-events-none');
          btn.classList.add('opacity-100');
        } else {
          btn.classList.add('opacity-0', 'pointer-events-none');
          btn.classList.remove('opacity-100');
        }
      }, { passive: true });
    }

    // Click listener: only once (button is in layout body, persists)
    if (!window.__backToTopClickSetup) {
      window.__backToTopClickSetup = true;
      backToTopBtn.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    }
  }

  // Initial run
  setupGlobalScrollBar();
  setupBackToTop();
  
  // Page navigation loader — tracks real resource loading
  let navLoaderTimer = null;
  let bottomLoaderTimer = null;
  const navLoader = document.getElementById('nav-loader');
  const navLoaderBar = navLoader?.querySelector('div');
  const bottomLoader = document.getElementById('bottom-loader');
  const bottomLoaderBar = bottomLoader?.querySelector('div');

  let loaderActive = false;

  function setProgress(pct) {
    const clamped = Math.max(0, Math.min(100, pct));
    if (navLoaderBar) navLoaderBar.style.width = clamped + '%';
    if (bottomLoaderBar) bottomLoaderBar.style.width = clamped + '%';
  }

  function startNavLoader() {
    if (navLoader && navLoaderBar) {
      clearTimeout(navLoaderTimer);
      navLoader.classList.remove('hidden');
      navLoaderBar.style.transition = 'width 0.3s ease-out';
      navLoaderBar.style.width = '3%';
    }

    if (bottomLoader && bottomLoaderBar) {
      clearTimeout(bottomLoaderTimer);
      bottomLoader.style.transform = 'translateY(0)';
      bottomLoaderBar.style.width = '3%';
      bottomLoaderBar.style.transition = 'width 0.3s ease-out';
    }
  }

  function completeNavLoader() {
    loaderActive = false;
    clearTimeout(window.__loaderFallbackTimer);
    clearInterval(window.__loaderFallbackInterval);

    if (resourceObserver) {
      resourceObserver.disconnect();
      resourceObserver = null;
    }

    requestAnimationFrame(() => {
      if (navLoaderBar) { navLoaderBar.style.width = '100%'; navLoaderBar.style.transition = 'width 0.15s ease-out'; }
      if (bottomLoaderBar) { bottomLoaderBar.style.width = '100%'; bottomLoaderBar.style.transition = 'width 0.15s ease-out'; }

      if (navLoader) {
        clearTimeout(navLoaderTimer);
        navLoaderTimer = setTimeout(() => {
          navLoader.classList.add('hidden');
          if (navLoaderBar) navLoaderBar.style.width = '0%';
        }, 300);
      }

      if (bottomLoader) {
        clearTimeout(bottomLoaderTimer);
        bottomLoaderTimer = setTimeout(() => {
          bottomLoader.style.transform = 'translateY(100%)';
        setTimeout(() => {
          bottomLoaderBar.style.width = '0%';
        }, 300);
      }, 250);
    }
  }

  if (!window._layoutListenersInited) {
    document.addEventListener('astro:before-preparation', startNavLoader);
    document.addEventListener('astro:error', completeNavLoader);
    document.addEventListener('astro:page-load', () => {
      completeNavLoader();
      setupGlobalScrollBar();
      setupBackToTop();
      showPerfMetrics();
    });
    window._layoutListenersInited = true;
  }
}
