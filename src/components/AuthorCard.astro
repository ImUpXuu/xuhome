---
import { siteConfig } from '../config/site';
---
<div class="bg-white dark:bg-slate-800 border-2 border-[#0284c7]/30 p-5 rounded-sm animate-card-entrance opacity-0" style="animation-delay: 0.03s">
  <div class="flex items-center justify-center mb-4">
    <div class="w-20 h-20 sm:w-24 sm:h-24 rounded-sm bg-[#0ea5e9] border-4 border-[#0284c7] shadow-[4px_4px_0px_0px_#0284c7] overflow-hidden flex items-center justify-center">
      <img src={siteConfig.avatar} alt={siteConfig.author} width="96" height="96" loading="lazy" class="w-full h-full object-cover" />
    </div>
  </div>
  <h2 class="text-lg sm:text-xl font-black text-[#0284c7] text-center tracking-wider mb-1">{siteConfig.author}</h2>
  <div class="h-0 border-b-2 border-dashed border-[#0284c7]/20 my-2.5 w-3/5 mx-auto"></div>
  <div class="text-xs sm:text-sm font-bold text-slate-600 dark:text-slate-400 text-center leading-relaxed mb-3">
    逐光而上！
  </div>
  <div class="flex justify-center gap-3 flex-wrap">
    <a href={siteConfig.socials.bilibili} target="_blank" rel="noopener noreferrer" class="flex items-center gap-1 text-xs font-black text-[#0284c7] bg-[#fde68a] px-2.5 py-1 rounded-sm border-2 border-[#0284c7] hover:bg-[#f59e0b] hover:text-white transition-all" title="Bilibili">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M17.813 4.653h.854c1.51.054 2.769.578 3.773 1.574 1.004.995 1.524 2.249 1.56 3.76v7.36c-.036 1.51-.556 2.769-1.56 3.773s-2.262 1.524-3.773 1.56H5.333c-1.51-.036-2.769-.556-3.773-1.56S.036 18.858 0 17.347v-7.36c.036-1.511.556-2.765 1.56-3.76 1.004-.996 2.262-1.52 3.773-1.574h.774l-1.174-1.12a1.234 1.234 0 0 1-.373-.906c0-.356.124-.658.373-.907l.027-.027c.267-.249.573-.373.92-.373.347 0 .653.124.92.373L9.653 4.44c.071.071.134.142.187.213h4.267a.836.836 0 0 1 .16-.186l1.947-1.947c.267-.249.573-.373.92-.373.347 0 .662.151.928.4.267.249.382.551.347.907l-1.36 1.334zm-10.7 2.453c-1.098 0-2.004.386-2.716 1.16-.713.773-1.07 1.716-1.07 2.827v5.333c0 1.111.357 2.054 1.07 2.827.712.773 1.618 1.16 2.716 1.16h10.694c1.098 0 2.004-.387 2.716-1.16.713-.773 1.07-1.716 1.07-2.827v-5.333c0-1.111-.357-2.054-1.07-2.827-.712-.773-1.618-1.16-2.716-1.16H7.113zm10.154 2.773a.8.8 0 0 1 .587.267.8.8 0 0 1 .266.613v2.667a.8.8 0 0 1-.266.613.8.8 0 0 1-.587.267.8.8 0 0 1-.587-.267.8.8 0 0 1-.266-.613v-2.667a.8.8 0 0 1 .266-.613.8.8 0 0 1 .587-.267zm-6.4 0a.8.8 0 0 1 .587.267.8.8 0 0 1 .266.613v2.667a.8.8 0 0 1-.266.613.8.8 0 0 1-.587.267.8.8 0 0 1-.586-.267.8.8 0 0 1-.267-.613v-2.667a.8.8 0 0 1 .267-.613.8.8 0 0 1 .586-.267z"/></svg>
      <span>UPXUU</span>
    </a>
    <a href={siteConfig.socials.github} target="_blank" rel="noopener noreferrer" class="flex items-center gap-1 text-xs font-black text-[#0284c7] bg-[#fde68a] px-2.5 py-1 rounded-sm border-2 border-[#0284c7] hover:bg-[#f59e0b] hover:text-white transition-all" title="GitHub">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
    </a>
    <a href={`mailto:${siteConfig.socials.email}`} class="flex items-center gap-1 text-xs font-black text-[#0284c7] bg-[#fde68a] px-2.5 py-1 rounded-sm border-2 border-[#0284c7] hover:bg-[#f59e0b] hover:text-white transition-all" title={siteConfig.socials.email}>
      <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 stroke-[2.5]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
    </a>
  </div>
</div>
