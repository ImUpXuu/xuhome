---
import { welcomeConfig, siteConfig } from '../config/site';
---

<script define:vars={{ welcomeConfig, siteConfig }}>
(function() {
  var VISIT_SESSION_KEY = welcomeConfig.sessionKey;
  var autoCloseTimer = null;
  var hasShownToast = false;

  function createWelcomeToast() {
    var toast = document.createElement('div');
    toast.id = 'welcome-toast';
    toast.setAttribute('data-nosnippet', 'true');
    toast.setAttribute('aria-hidden', 'true');
    toast.className = 'fixed bottom-4 left-2 right-2 sm:left-4 sm:right-auto z-[2000] translate-y-[calc(100%+20px)] opacity-0 transition-all duration-500 ease-out';
    toast.innerHTML = [
      '<div class="bg-[#faf8f5] dark:bg-slate-800 border-2 border-[#0284c7] shadow-[4px_4px_0px_0px_#0284c7] rounded-sm p-2 sm:p-0">',
      '  <div class="bg-red-500 text-white text-[10px] sm:text-xs font-black text-center px-2 py-1.5 rounded-sm mb-1.5">',
      '    ⚠ 本站唯一官方域名 UPXUU.COM · 任何其他域名皆为盗版 | Official: UPXUU.COM · All others are pirated',
      '  </div>',
      '  <div class="flex flex-wrap items-center gap-x-2 gap-y-1 px-2 sm:px-3 py-1.5 sm:py-0 sm:h-9">',
      '    <span class="text-xs font-black text-[#0284c7]">👋</span>',
      '    <span id="welcome-message" class="text-xs font-bold text-slate-700 dark:text-slate-200">加载中...</span>',
      '    <span class="text-slate-300 dark:text-slate-600 text-xs font-black hidden sm:inline">|</span>',
      '    <span id="welcome-stats" class="text-xs font-bold text-slate-500 dark:text-slate-400"></span>',
      '    <div class="flex items-center gap-1.5 ml-auto sm:ml-1 shrink-0">',
      '      <a href="' + siteConfig.socials.qqGroup + '" target="_blank" rel="noopener noreferrer" class="text-[10px] font-black text-blue-500 hover:text-[#0284c7] dark:hover:text-blue-400 transition-colors shrink-0 uppercase tracking-wider">QQ群</a>',
      '      <span class="text-slate-300 dark:text-slate-600 text-[10px] font-black">|</span>',
      '      <a href="' + siteConfig.socials.subscribe + '" class="text-[10px] font-black text-green-500 hover:text-[#0284c7] dark:hover:text-green-400 transition-colors shrink-0 uppercase tracking-wider">订阅</a>',
      '      <span class="text-slate-300 dark:text-slate-600 text-[10px] font-black">|</span>',
      '      <a href="javascript:void(0)" class="js-copy-rss text-[10px] font-black text-orange-500 hover:text-[#0284c7] dark:hover:text-orange-400 transition-colors shrink-0 uppercase tracking-wider">RSS</a>',
      '      <button class="js-close-toast text-slate-400 hover:text-[#0284c7] dark:hover:text-white transition-colors shrink-0 ml-1" aria-label="关闭">',
      '        <svg class="w-3 h-3 stroke-[3]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12"></path></svg>',
      '      </button>',
      '    </div>',
      '  </div>',
      '</div>'
    ].join('\n');
    document.body.appendChild(toast);

    var closeBtn = toast.querySelector('.js-close-toast');
    if (closeBtn) closeBtn.addEventListener('click', closeWelcomeToast);

    var rssBtn = toast.querySelector('.js-copy-rss');
    if (rssBtn) rssBtn.addEventListener('click', copyRssLink);

    return toast;
  }

  function closeWelcomeToast() {
    if (autoCloseTimer) { clearTimeout(autoCloseTimer); autoCloseTimer = null; }
    var toast = document.getElementById('welcome-toast');
    if (toast) {
      toast.classList.remove('translate-y-0', 'opacity-100');
      toast.classList.add('translate-y-[calc(100%+20px)]', 'opacity-0');
      setTimeout(function() { toast.remove(); }, 500);
    }
  }

  async function fetchLocationAndWeather() {
    try {
      var res = await fetch(welcomeConfig.weatherApi);
      var data = await res.json();
      var msgEl = document.getElementById('welcome-message');
      if (!msgEl) return;
      var loc = (data.district ? data.city + data.district : data.city) || '远方';
      var weatherText = data.weather ? data.weather + ' ' + data.temperature + '°C' : '';
      var parts = ['Hi！来自' + loc + '的朋友'];
      if (weatherText) parts.push(weatherText);
      msgEl.textContent = parts.join(' · ');
    } catch {
      var msgEl = document.getElementById('welcome-message');
      if (msgEl) msgEl.textContent = welcomeConfig.fallbackMessage;
    }
  }

  async function fetchStats() {
    try {
      var alltimeRes = await fetch(siteConfig.analytics.statsApi.alltime);
      var alltimeData = await alltimeRes.json();
      var pv = alltimeData ? (typeof alltimeData.pageviews === 'object' ? (alltimeData.pageviews?.value ?? 0) : (alltimeData.pageviews ?? 0)) : 0;
      var text = pv ? '你是第 ' + pv.toLocaleString() + ' 位访客' : '';
      var statsEl = document.getElementById('welcome-stats');
      if (statsEl) statsEl.textContent = text;
    } catch {}
  }

  async function showWelcomeToast() {
    if (hasShownToast) return;
    var toast = createWelcomeToast();
    setTimeout(function() {
      toast.classList.remove('translate-y-[calc(100%+20px)]', 'opacity-0');
      toast.classList.add('translate-y-0', 'opacity-100');
    }, 100);
    hasShownToast = true;
    autoCloseTimer = setTimeout(closeWelcomeToast, welcomeConfig.duration);
    Promise.allSettled([fetchLocationAndWeather(), fetchStats()]);
  }

  function init() {
    if (sessionStorage.getItem(VISIT_SESSION_KEY)) return;
    sessionStorage.setItem(VISIT_SESSION_KEY, 'true');
    showWelcomeToast();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }

  window.closeWelcomeToast = closeWelcomeToast;

  function copyRssLink() {
    try { navigator.clipboard.writeText(window.location.origin + '/rss.xml'); } catch { }
  }
  window.copyRssLink = copyRssLink;
})();
</script>
