---
import type { PostItem } from '../utils/postsFetcher';

interface Props {
  posts: PostItem[];
}

const { posts } = Astro.props;

// Group posts by Year+Month
const groupedPosts: Record<string, PostItem[]> = {};
posts.forEach(p => {
  if (!p.date || p.date === '未知时间') return;
  const parts = p.date.split('-');
  if (parts.length < 2) return;
  const ym = `${parts[0]}年${parts[1]}月`;
  if (!groupedPosts[ym]) groupedPosts[ym] = [];
  groupedPosts[ym].push(p);
});

const months = Object.keys(groupedPosts);
---

{months.length > 0 && (
  <div class="bg-white border-4 border-[#0284c7] p-4 shadow-[6px_6px_0px_0px_#0284c7] rounded-sm xl:sticky xl:top-[calc(100px+320px)] w-full animate-card-entrance opacity-0" style="animation-delay: 0.12s">
    <h3 class="font-black text-[#0284c7] uppercase tracking-wider mb-4 border-b-2 border-dashed border-[#0284c7]/30 pb-2 flex items-center gap-2 text-sm">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 stroke-[2.5]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
      </svg>
      <span>归档目录</span>
    </h3>
    
    <div class="space-y-4 max-h-[50vh] overflow-y-auto pr-1 custom-scrollbar" id="archive-list-container">
      {Object.entries(groupedPosts).map(([ym, ymPosts], idx) => (
        <div class="archive-group" data-ym={ym}>
          <div 
            class="archive-header text-xs font-black text-slate-700 mb-2 relative flex items-center cursor-pointer hover:text-[#0ea5e9] transition-colors select-none"
          >
            <span class="w-2 h-2 bg-[#fde68a] border-2 border-[#0284c7] inline-block mr-2 shadow-[1px_1px_0px_0px_#0284c7]"></span>
            <span class="flex-1">{ym}</span>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 stroke-[2.5] chevron-icon transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </div>
          
          <div class={`archive-posts pl-3 border-l-2 border-dashed border-[#0284c7]/20 ml-[3px] space-y-2 animate-fade-in ${idx > 0 ? 'hidden' : ''}`}>
            {ymPosts.map(post => {
              const dParts = post.date.split('-');
              const displayDate = dParts.length >= 3 ? `${dParts[1]}-${dParts[2]}` : '';
              return (
                <a 
                  href={`/posts/${encodeURIComponent(post.slug)}`}
                  data-astro-prefetch
                  class="block text-[11px] font-bold text-[#0284c7]/80 hover:text-[#0ea5e9] cursor-pointer truncate transition-colors py-0.5 relative z-10"
                  title={post.title}
                >
                  <span class="mr-1.5 text-slate-400 font-mono text-[9px]">{displayDate}</span>
                  {post.title}
                </a>
              );
            })}
          </div>
        </div>
      ))}
    </div>
  </div>
)}

<script is:inline data-astro-rerun>
  const archiveContainer = document.getElementById('archive-list-container');
  if (archiveContainer) {
    const groups = archiveContainer.querySelectorAll('.archive-group');
    groups.forEach((group, idx) => {
      const header = group.querySelector('.archive-header');
      const postsList = group.querySelector('.archive-posts');
      const chevron = group.querySelector('.chevron-icon');

      // Adjust initial chevron rotate state
      if (idx > 0) {
        if (chevron) chevron.style.transform = 'rotate(-90deg)';
      }

      if (header && postsList) {
        header.addEventListener('click', () => {
          const isHidden = postsList.classList.contains('hidden');
          if (isHidden) {
            postsList.classList.remove('hidden');
            if (chevron) chevron.style.transform = 'rotate(0deg)';
          } else {
            postsList.classList.add('hidden');
            if (chevron) chevron.style.transform = 'rotate(-90deg)';
          }
        });
      }
    });
  }
</script>
