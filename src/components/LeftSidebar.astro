---import CalendarWidget from './CalendarWidget.svelte';import SidebarTags from './SidebarTags.astro';import AuthorCard from './AuthorCard.astro';interface CalendarPost {  slug: string;  title: string;  date: string;  description: string;}export interface Props {  posts: CalendarPost[];  tags: { name: string; count: number }[];  activeTag?: string | null;  showCalendar?: boolean;  showTags?: boolean;  showAuthor?: boolean;}const { posts, tags, activeTag = null, showCalendar = true, showTags = true, showAuthor = true } = Astro.props;---{  showAuthor && <AuthorCard />}{  showCalendar && <CalendarWidget posts={posts} client:idle />}{  showTags && <SidebarTags tags={tags} activeTag={activeTag} />}